#include <bits/stdc++.h>
using namespace std;
 
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
 
    int t; cin >> t;
    while(t--){
        int n, k; cin >> n >> k;
        string s; cin >> s;
        s = " " + s;
 
        const int INF = 1e9;
        int ans = INF; //min flips
 
        for (int R=0; R<=n; R++){
            vector <vector <int>> dp(n+1, vector <int> (n+1, INF));
            dp[0][0] = 0;
 
            for (int i=1; i<=n; i++){
                for (int r=0; r<i; r++){
                    if (dp[i-1][r] == INF) continue;
                    if(r>=k) dp[i][r] = min(dp[i][r], dp[i-1][r] + (s[i]=='R'));
                    if ((n-R)-((i-1)-r) >= k) dp[i][r+1] = min(dp[i][r+1], dp[i-1][r] + (s[i]=='L'));
                }
                ans = min(ans, dp[n][R]);
            }
        }
        cout << (ans==INF ? -1 : ans) << endl;
    }
    return 0;
}